{
  "name": "@vibe-sync/cli",
  "version": "1.0.0",
  "description": "CLI for vibe-sync - AI coding tool config synchronizer",
  "type": "module",
  "bin": {
    "vibe-sync": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "inquirer": "^12.3.2",
    "chalk": "^5.3.0",
    "ora": "^8.1.1",
    "jsonc-parser": "^3.3.1",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/inquirer": "^9.0.7",
    "@vitest/coverage-v8": "^3.0.5",
    "@vitest/ui": "^3.0.5",
    "tsx": "^4.19.2",
    "tsup": "^8.3.5",
    "vitest": "^3.0.5",
    "mock-fs": "^5.4.0",
    "@types/mock-fs": "^4.13.4"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  }
}
