{
  "name": "@vibe-sync/cli",
  "version": "1.0.0",
  "description": "CLI for vibe-sync - AI coding tool config synchronizer",
  "type": "module",
  "bin": {
    "vibe-sync": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/mock-fs": "^4.13.4",
    "@types/node": "^25.0.10",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "gray-matter": "^4.0.3",
    "inquirer": "^13.2.1",
    "jsonc-parser": "^3.3.1",
    "mock-fs": "^5.5.0",
    "ora": "^9.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  }
}
